<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<title>Prompt OS Galgame</title>
<hta:application
    id="app"
    applicationname="Prompt OS Galgame"
    border="dialog"
    innerborder="yes"
    caption="yes"
    contextmenu="no"
    maximizebutton="no"
    minimizebutton="yes"
    sysmenu="yes"
    icon="shell32.dll"
    singleinstance="yes"
    windowstate="normal"
/>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{background:#0d1117;color:#c9d1d9;font-family:system-ui,sans-serif;height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center}
h1{font-size:1.4em;color:#58a6ff;margin-bottom:4px}
.sub{color:#484f58;font-size:0.8em;margin-bottom:8px}
.version{color:#d2a8ff;font-size:0.7em;margin-bottom:20px}
.btn{display:inline-block;padding:10px 28px;background:#1a3a5c;border:1px solid #58a6ff;border-radius:8px;color:#58a6ff;font-size:0.95em;cursor:pointer;margin:4px}
.btn:hover{background:#1f4a7a}
.btn.stop{background:#3d1a1a;border-color:#da3633;color:#f85149}
.btn.stop:hover{background:#4d2020}
.status{color:#8b949e;font-size:0.85em;margin-top:16px;min-height:22px}
.hint{color:#484f58;font-size:0.7em;margin-top:12px}
</style>
</head>
<body onbeforeunload="if(document.getElementById('btnStop').style.display!=='none'){try{KillAll()}catch(e){}}">
<h1>🎮 Prompt OS Galgame</h1>
<div class="sub">AI Interactive Narrative Engine</div>
<div class="version">React UI + FastAPI Backend</div>
<button class="btn" id="btnStart" onclick="startGame()">🚀 启动游戏</button>
<button class="btn stop" id="btnStop" onclick="stopGame()" style="display:none">⏻ 关闭服务器</button>
<div class="status" id="status">点击上方按钮启动</div>
<div class="hint" id="hint">将同时启动后端 API 和前端 UI</div>

<script language="VBScript">
Dim objShell, strDir, pidBackend, pidFrontend

Sub Window_OnLoad()
    window.resizeTo 400, 320
    window.moveTo (screen.availWidth - 400) / 2, (screen.availHeight - 320) / 2
    Set objShell = CreateObject("WScript.Shell")
    Set objFSO = CreateObject("Scripting.FileSystemObject")
    strDir = objFSO.GetParentFolderName(objFSO.GetAbsolutePathName("."))
    objShell.CurrentDirectory = strDir
End Sub

Sub LaunchServers()
    On Error Resume Next
    objShell.Run "cmd /c python --version > nul 2>&1", 0, True
    If Err.Number <> 0 Then
        document.getElementById("status").innerText = "未找到 Python，请安装 Python 3.10+"
        document.getElementById("status").style.color = "#f85149"
        Exit Sub
    End If
    On Error Goto 0

    On Error Resume Next
    objShell.Run "cmd /c node --version > nul 2>&1", 0, True
    If Err.Number <> 0 Then
        document.getElementById("status").innerText = "未找到 Node.js，请安装 Node.js 18+"
        document.getElementById("status").style.color = "#f85149"
        Exit Sub
    End If
    On Error Goto 0

    ' Install deps if needed
    Dim missingPy, missingNpm
    On Error Resume Next
    objShell.Run "cmd /c python -c ""import fastapi"" > nul 2>&1", 0, True
    If Err.Number <> 0 Then missingPy = True
    On Error Goto 0
    If missingPy Then
        document.getElementById("status").innerText = "首次运行，正在安装 Python 依赖..."
        objShell.Run "cmd /c pip install -r requirements.txt --quiet > nul 2>&1", 0, True
    End If

    If Not objFSO.FolderExists(strDir & "\frontend\node_modules") Then
        document.getElementById("status").innerText = "首次运行，正在安装前端依赖..."
        objShell.Run "cmd /c cd frontend && npm install --quiet > nul 2>&1", 0, True
    End If

    ' Start backend
    objShell.Run "cmd /c python -m uvicorn ui.web_app:app --host 0.0.0.0 --port 8000", 0, False

    ' Start frontend
    objShell.Run "cmd /c cd frontend && npm run dev", 0, False
End Sub

Sub KillAll()
    objShell.Run "cmd /c taskkill /f /im node.exe > nul 2>&1", 0, False
    objShell.Run "cmd /c taskkill /f /im python.exe > nul 2>&1", 0, False
End Sub
</script>

<script>
function startGame(){
    document.getElementById('btnStart').style.display = 'none';
    document.getElementById('status').innerText = '正在启动服务器...';
    document.getElementById('status').style.color = '#8b949e';
    document.getElementById('hint').innerText = '后端 :8000  |  前端 :5173';

    try { LaunchServers(); } catch(e){}

    setTimeout(function(){
        try {
            var shell = new ActiveXObject('WScript.Shell');
            shell.Run('http://localhost:5173');
        } catch(e){}
        document.getElementById('status').innerText = '游戏已在浏览器中打开';
        document.getElementById('status').style.color = '#7ee787';
        document.getElementById('btnStop').style.display = 'inline-block';
        document.getElementById('hint').innerText = '访问 http://localhost:5173';
    }, 6000);
}

function stopGame(){
    if(confirm('确定要关闭所有服务器？')){
        try { KillAll(); } catch(e){}
        document.getElementById('status').innerText = '服务器已关闭 — 可重新启动';
        document.getElementById('status').style.color = '#8b949e';
        document.getElementById('btnStart').style.display = 'inline-block';
        document.getElementById('btnStop').style.display = 'none';
        document.getElementById('hint').innerText = '将同时启动后端 API 和前端 UI';
    }
}
</script>
</body>
</html>
